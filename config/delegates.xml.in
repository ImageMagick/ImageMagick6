<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE delegatemap [
  <!ELEMENT delegatemap (delegate)+>
  <!ATTLIST delegatemap xmlns CDATA #FIXED ''>
  <!ELEMENT delegate EMPTY>
  <!ATTLIST delegate xmlns CDATA #FIXED '' command CDATA #REQUIRED
    decode NMTOKEN #IMPLIED encode NMTOKEN #IMPLIED mode NMTOKEN #IMPLIED
    spawn NMTOKEN #IMPLIED stealth NMTOKEN #IMPLIED>
]>
<!--
  Delegate command file.

  Commands which specify

    decode="in_format" encode="out_format"

  specify the rules for converting from in_format to out_format.  Use these
  rules to translate directly between formats.

  Commands which specify only

    decode="in_format"

  specify the rules for converting from in_format to some format that
  ImageMagick automatically recognizes. Use these rules to decode formats.

  Commands which specify only

   encode="out_format"

  specify the rules for an "encoder" which may accept any input format.

  The substitution rules are as follows:

    %a  authentication passphrase
    %b  image file size in bytes
    %g  image geometry
    %h  image rows (height)
    %i  input image filename
    %#  input image signature
    %m  input image format
    %o  output image filename
    %p  page number
    %q  input image depth
    %s  scene number
    %u  unique temporary filename
    %w  image columns (width)
    %x  input image x resolution
    %y  input image y resolution
    %Q  image compression quality

  Set option delegate:bimodal=true to process bimodal delegates otherwise they
  are ignored.

  If stealth="True" the delegate is not listed in user requested
  "-list delegate" listings. These are typically special internal delegates.

  If spawn="True", ImageMagick does not wait for the delegate to finish, nor
  will it read any output image.
-->
<delegatemap>
  <delegate decode="bpg" command="@CMD_QUOTE@@BPGDecodeDelegate@@CMD_QUOTE@ -b 16 -o @CMD_QUOTE@%o.png@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%o.png@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="png" encode="bpg" command="@CMD_QUOTE@@BPGEncodeDelegate@@CMD_QUOTE@ -b 12 -q @CMD_QUOTE@%~@CMD_QUOTE@ -o @CMD_QUOTE@%o@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@"/>
  <delegate decode="blender" command="@CMD_QUOTE@@BlenderDecodeDelegate@@CMD_QUOTE@ -b @CMD_QUOTE@%i@CMD_QUOTE@ -F PNG -o @CMD_QUOTE@%o@CMD_QUOTE@@CMD_QUOTE@\n@CMD_QUOTE@@ConvertDelegate@@CMD_QUOTE@ -concatenate @CMD_QUOTE@%o*.png@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="browse" stealth="True" spawn="True" command="@CMD_QUOTE@@BrowseDelegate@@CMD_QUOTE@ https://imagemagick.org/; @RMDelegate@ @CMD_QUOTE@%i@CMD_QUOTE@"/>
  <delegate decode="https:decode" command="@CMD_QUOTE@@WWWDecodeDelegate@@CMD_QUOTE@ -s -L -o @CMD_QUOTE@%u.dat@CMD_QUOTE@ @CMD_QUOTE@https:%M@CMD_QUOTE@"/>
  <delegate decode="doc" command="@CMD_QUOTE@@DOCDecodeDelegate@@CMD_QUOTE@ --convert-to pdf --outdir `dirname @CMD_QUOTE@%i@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@ 2&gt; @CMD_QUOTE@%u@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%i.pdf@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="docx" command="@CMD_QUOTE@@DOCDecodeDelegate@@CMD_QUOTE@ --convert-to pdf --outdir `dirname @CMD_QUOTE@%i@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@ 2&gt; @CMD_QUOTE@%u@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%i.pdf@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="dng:decode" command="@MKDIRDelegate@ @CMD_QUOTE@%u-config@CMD_QUOTE@;@MVDelegate@ @CMD_QUOTE@%i@CMD_QUOTE@ @CMD_QUOTE@%i.%e@CMD_QUOTE@; @CMD_QUOTE@@DNGDecodeDelegate@@CMD_QUOTE@ --import @CMD_QUOTE@%i.%e@CMD_QUOTE@ @CMD_QUOTE@%u.tif@CMD_QUOTE@ --core --configdir @CMD_QUOTE@%u-config@CMD_QUOTE@ &gt; @CMD_QUOTE@%u@CMD_QUOTE@;@RMDelegate@ -r @CMD_QUOTE@%u-config@CMD_QUOTE@"/>
  <delegate decode="dot" command='@CMD_QUOTE@@GVCDecodeDelegate@@CMD_QUOTE@ -Tsvg @CMD_QUOTE@%i@CMD_QUOTE@ -o @CMD_QUOTE@%o@CMD_QUOTE@' />
  <delegate decode="dvi" command="@CMD_QUOTE@@DVIDecodeDelegate@@CMD_QUOTE@ -sstdout=%%stderr -o @CMD_QUOTE@%o@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@"/>
  <delegate decode="edit" stealth="True" command="@CMD_QUOTE@@EditorDelegate@@CMD_QUOTE@ -title @CMD_QUOTE@Edit Image Comment@CMD_QUOTE@ -e vi @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="emf" command="@CMD_QUOTE@@DOCDecodeDelegate@@CMD_QUOTE@ --convert-to pdf --outdir `dirname @CMD_QUOTE@%i@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@ 2&gt; @CMD_QUOTE@%u@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%i.pdf@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="eps" encode="pdf" mode="bi" command="@CMD_QUOTE@@PSDelegate@@CMD_QUOTE@ -sstdout=%%stderr -dQUIET -dSAFER -dBATCH -dNOPAUSE -dNOPROMPT -dMaxBitmap=500000000 @CMD_QUOTE@-sDEVICE=@GSPDFDevice@@CMD_QUOTE@ @CMD_QUOTE@-sOutputFile=%o@CMD_QUOTE@ @CMD_QUOTE@-f%i@CMD_QUOTE@"/>
  <delegate decode="eps" encode="ps" mode="bi" command="@CMD_QUOTE@@PSDelegate@@CMD_QUOTE@ -sstdout=%%stderr -dQUIET -dSAFER -dBATCH -dNOPAUSE -dNOPROMPT -dMaxBitmap=500000000 -dAlignToPixels=0 -dGridFitTT=2 @CMD_QUOTE@-sDEVICE=@GSPSDevice@@CMD_QUOTE@ @CMD_QUOTE@-sOutputFile=%o@CMD_QUOTE@ @CMD_QUOTE@-f%i@CMD_QUOTE@"/>
  <delegate decode="epub" command="@CMD_QUOTE@@DOCDecodeDelegate@@CMD_QUOTE@ --convert-to pdf --outdir `dirname @CMD_QUOTE@%i@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@ 2&gt; @CMD_QUOTE@%u@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%i.pdf@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="hpg" command="@CMD_QUOTE@@HPGLDecodeDelegate@@CMD_QUOTE@ -sstdout=%%stderr -m eps -f `basename @CMD_QUOTE@%o@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@;     @MVDelegate@ -f `basename @CMD_QUOTE@%o@CMD_QUOTE@` @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="hpgl" command="@CMD_QUOTE@@HPGLDecodeDelegate@@CMD_QUOTE@ -sstdout=%%stderr -m eps -f `basename @CMD_QUOTE@%o@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@;     @MVDelegate@ -f `basename @CMD_QUOTE@%o@CMD_QUOTE@` @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="htm" command="@CMD_QUOTE@@HTMLDecodeDelegate@@CMD_QUOTE@ -U -o @CMD_QUOTE@%o@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@"/>
  <delegate decode="html" command="@CMD_QUOTE@@HTMLDecodeDelegate@@CMD_QUOTE@ -U -o @CMD_QUOTE@%o@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@"/>
  <delegate decode="ilbm" command="@CMD_QUOTE@@ILBMDecodeDelegate@@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@ &gt; @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="jpg" encode="lep" mode="encode" command="@CMD_QUOTE@@LEPDelegate@@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="jxr" command="@MVDelegate@ @CMD_QUOTE@%i@CMD_QUOTE@ @CMD_QUOTE@%i.jxr@CMD_QUOTE@; @CMD_QUOTE@@JXRDecodeDelegate@@CMD_QUOTE@ -i @CMD_QUOTE@%i.jxr@CMD_QUOTE@ -o @CMD_QUOTE@%o.tiff@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%i.jxr@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%o.tiff@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="lep" mode="decode" command="@CMD_QUOTE@@LEPDelegate@@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="miff" encode="show" spawn="True" command="@CMD_QUOTE@@DisplayDelegate@@CMD_QUOTE@ -immutable -delay 0 -title @CMD_QUOTE@%M@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@"/>
  <delegate decode="miff" encode="win" stealth="True" spawn="True" command="@CMD_QUOTE@@DisplayDelegate@@CMD_QUOTE@ -immutable -delay 0 -title @CMD_QUOTE@%M@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@"/>
  <delegate decode="odg" command="@CMD_QUOTE@@DOCDecodeDelegate@@CMD_QUOTE@ --convert-to pdf --outdir `dirname @CMD_QUOTE@%i@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@ 2&gt; @CMD_QUOTE@%u@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%i.pdf@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="odt" command="@CMD_QUOTE@@DOCDecodeDelegate@@CMD_QUOTE@ --convert-to pdf --outdir `dirname @CMD_QUOTE@%i@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@ 2&gt; @CMD_QUOTE@%u@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%i.pdf@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="pcl:cmyk" stealth="True" command="@CMD_QUOTE@@PCLDelegate@@CMD_QUOTE@ -dQUIET -dSAFER -dBATCH -dNOPAUSE -dNOPROMPT -dMaxBitmap=500000000 -dAlignToPixels=0 -dGridFitTT=2 @CMD_QUOTE@-sDEVICE=@PCLCMYKDevice@@CMD_QUOTE@ -dTextAlphaBits=%u -dGraphicsAlphaBits=%u @CMD_QUOTE@-r%s@CMD_QUOTE@ %s @CMD_QUOTE@-sOutputFile=%s@CMD_QUOTE@ @CMD_QUOTE@%s@CMD_QUOTE@"/>
  <delegate decode="pcl:color" stealth="True" command="@CMD_QUOTE@@PCLDelegate@@CMD_QUOTE@ -dQUIET -dSAFER -dBATCH -dNOPAUSE -dNOPROMPT -dMaxBitmap=500000000 -dAlignToPixels=0 -dGridFitTT=2 @CMD_QUOTE@-sDEVICE=@PCLColorDevice@@CMD_QUOTE@ -dTextAlphaBits=%u -dGraphicsAlphaBits=%u @CMD_QUOTE@-r%s@CMD_QUOTE@ %s @CMD_QUOTE@-sOutputFile=%s@CMD_QUOTE@ @CMD_QUOTE@%s@CMD_QUOTE@"/>
  <delegate decode="pcl:mono" stealth="True" command="@CMD_QUOTE@@PCLDelegate@@CMD_QUOTE@ -dQUIET -dSAFER -dBATCH -dNOPAUSE -dNOPROMPT -dMaxBitmap=500000000 -dAlignToPixels=0 -dGridFitTT=2 @CMD_QUOTE@-sDEVICE=@PCLMonoDevice@@CMD_QUOTE@ -dTextAlphaBits=%u -dGraphicsAlphaBits=%u @CMD_QUOTE@-r%s@CMD_QUOTE@ %s @CMD_QUOTE@-sOutputFile=%s@CMD_QUOTE@ @CMD_QUOTE@%s@CMD_QUOTE@"/>
  <delegate decode="pdf" encode="eps" mode="bi" command="@CMD_QUOTE@@PSDelegate@@CMD_QUOTE@ -sstdout=%%stderr -dQUIET -dSAFER -dBATCH -dNOPAUSE -dNOPROMPT -dMaxBitmap=500000000 -dAlignToPixels=0 -dGridFitTT=2 @CMD_QUOTE@-sDEVICE=@GSEPSDevice@@CMD_QUOTE@ @CMD_QUOTE@-sPDFPassword=%a@CMD_QUOTE@ @CMD_QUOTE@-sOutputFile=%o@CMD_QUOTE@ @CMD_QUOTE@-f%i@CMD_QUOTE@"/>
  <delegate decode="pdf" encode="ps" mode="bi" command="@CMD_QUOTE@@PSDelegate@@CMD_QUOTE@ -sstdout=%%stderr -dQUIET -dSAFER -dBATCH -dNOPAUSE -dNOPROMPT -dMaxBitmap=500000000 -dAlignToPixels=0 -dGridFitTT=2 @CMD_QUOTE@-sDEVICE=@GSPSDevice@@CMD_QUOTE@ @CMD_QUOTE@-sPDFPassword=%a@CMD_QUOTE@ @CMD_QUOTE@-sOutputFile=%o@CMD_QUOTE@ @CMD_QUOTE@-f%i@CMD_QUOTE@"/>
  <delegate decode="pnm" encode="trace" command="@CMD_QUOTE@@TraceEncodeDelegate@@CMD_QUOTE@ --svg --output @CMD_QUOTE@%o@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@"/>
  <delegate decode="png" encode="clipboard" command="@CMD_QUOTE@@ClipboardDelegate@@CMD_QUOTE@ -selection clipboard -t image/png @CMD_QUOTE@%i@CMD_QUOTE@"/>
  <delegate decode="clipboard" command="@CMD_QUOTE@@ClipboardDelegate@@CMD_QUOTE@ -selection clipboard -o &gt; @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="png" encode="webp" command="@CMD_QUOTE@@WebPEncodeDelegate@@CMD_QUOTE@ -quiet %Q @CMD_QUOTE@%i@CMD_QUOTE@ -o @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="pnm" encode="ilbm" mode="encode" command="@CMD_QUOTE@@ILBMEncodeDelegate@@CMD_QUOTE@ -24if @CMD_QUOTE@%i@CMD_QUOTE@ &gt; @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="tiff" encode="jxr" command="@MVDelegate@ @CMD_QUOTE@%i@CMD_QUOTE@ @CMD_QUOTE@%i.tiff@CMD_QUOTE@; @CMD_QUOTE@@JXREncodeDelegate@@CMD_QUOTE@ -i @CMD_QUOTE@%i.tiff@CMD_QUOTE@ -o @CMD_QUOTE@%o.jxr@CMD_QUOTE@ -q %Q; @MVDelegate@ @CMD_QUOTE@%i.tiff@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%o.jxr@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="tiff" encode="wdp" command="@MVDelegate@ @CMD_QUOTE@%i@CMD_QUOTE@ @CMD_QUOTE@%i.tiff@CMD_QUOTE@; @CMD_QUOTE@@JXREncodeDelegate@@CMD_QUOTE@ -i @CMD_QUOTE@%i.tiff@CMD_QUOTE@ -o @CMD_QUOTE@%o.jxr@CMD_QUOTE@ -q %Q; @MVDelegate@ @CMD_QUOTE@%i.tiff@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%o.jxr@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="ppt" command="@CMD_QUOTE@@DOCDecodeDelegate@@CMD_QUOTE@ --convert-to pdf --outdir `dirname @CMD_QUOTE@%i@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@ 2&gt; @CMD_QUOTE@%u@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%i.pdf@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="pptx" command="@CMD_QUOTE@@DOCDecodeDelegate@@CMD_QUOTE@ --convert-to pdf --outdir `dirname @CMD_QUOTE@%i@CMD_QUOTE@` @CMD_QUOTE@%i@CMD_QUOTE@ 2&gt; @CMD_QUOTE@%u@CMD_QUOTE@; @MVDelegate@ @CMD_QUOTE@%i.pdf@CMD_QUOTE@ @CMD_QUOTE@%o@CMD_QUOTE@"/>
  <delegate decode="ps" encode="prt" command='@CMD_QUOTE@@LPRDelegate@@CMD_QUOTE@ @CMD_QUOTE@%i@CMD_QUOTE@'/>
  <delegate decode="ps:alpha" stealth="True" command="@CMD_QUOTE@@PSDelegate@@CMD_QUOTE@ -sstdout=%%stderr -dQUIET -dSAFER -dBATCH -dNOPAUSE -dNOPROMPT -dMaxBitmap=500000000 -dAlignToPixels=0 -dGridFitTT=2 @CMD_QUOTE@-sDEVICE=@GSAlphaDevice@@CMD_QUOTE@ -dTextAlphaBits=%u -dGraphicsAlphaBits=%u @CMD_QUOTE@-r%s@CMD_QUOTE@ %s @CMD_QUOTE@-sOutputFile=%s@CMD_QUOTE@ @CMD_QUOTE@-f%s@CMD_QUOTE@ @CMD_QUOTE@-f%s@CMD_QUOTE@"/>
  <delegate decode="ps:cmyk" stealth="True" command="@CMD_QUOTE@@PSDelegate@@CMD_QUOTE@ -sstdout=%%stderr -dQUIET -dSAFER -dBATCH -dNOPAUSE -dNOPROMPT -dMaxBitmap=500000000 -dAlignToPixels=0 -dGridFitTT=2 @CMD_QUOTE@-sDEVICE=@GSCMYKDevice@@CMD_QUOTE@ -dTextAlphaBits=%u -dGraphicsAlphaBits=%u @CMD_QUOTE@-r%s@CMD_QUOTE@ %s @CMD_QUOTE@-sOutputFile=%s@CMD_QUOTE@ @CMD_QUOTE@-f%s@CMD_QUOTE@ @CMD_QUOTE@-f%s@CMD_QUOTE@"/>
